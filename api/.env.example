# ---- api.githotel.site ----
PORT=3008
APP_ORIGIN=https://app.githotel.site

# Supabase (Settings -> API Keys)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_... # secret key — NUNCA exponha no front
# JWT e verificado via JWKS publico em ${SUPABASE_URL}/auth/v1/.well-known/jwks.json
# (chaves ECC P-256, nao precisa de shared secret)

# GitHub (token de leitura de atividade publica; pode ser fine-grained)
GITHUB_TOKEN=ghp_...

# Economia (moedas por evento)
COINS_PER_COMMIT=1
COINS_PER_PR_OPENED=5
COINS_PER_PR_MERGED=20
COINS_PER_ISSUE_CLOSED=10
COINS_PER_STAR=15
DAILY_COMMIT_CAP=50
